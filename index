<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guilherme Boiaski — Software Developer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0D0D0D;
    --surface: #1A1A1A;
    --border: #2A2A2A;
    --text-muted: #BFBFBF;
    --text: #EDEDED;
    --neon: #39FF14;
    --neon-hover: #2ECC71;
    --neon-dark: #1F7A4D;
    --font: 'Poppins', sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    overflow-x: hidden;
    cursor: none;
  }

  /* ── CUSTOM CURSOR ── */
  #cursor {
    width: 12px; height: 12px;
    background: var(--neon);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    transition: transform .1s ease, width .2s ease, height .2s ease, opacity .2s ease;
    mix-blend-mode: difference;
  }
  #cursor-ring {
    width: 36px; height: 36px;
    border: 1.5px solid var(--neon);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%,-50%);
    transition: transform .18s ease, width .2s ease, height .2s ease, opacity .2s ease;
    opacity: .5;
  }
  body:has(a:hover) #cursor { transform: translate(-50%,-50%) scale(2); }
  body:has(a:hover) #cursor-ring { transform: translate(-50%,-50%) scale(1.5); opacity: .2; }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: .025;
    pointer-events: none;
    z-index: 9000;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--neon); border-radius: 2px; }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.4rem 5vw;
    border-bottom: 1px solid transparent;
    transition: background .4s, border-color .4s, backdrop-filter .4s;
  }
  nav.scrolled {
    background: rgba(13,13,13,.85);
    border-color: var(--border);
    backdrop-filter: blur(12px);
  }
  .nav-logo {
    font-family: var(--mono);
    font-size: .9rem;
    font-weight: 700;
    color: var(--neon);
    letter-spacing: .05em;
    text-decoration: none;
  }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }
  .nav-links a {
    font-size: .82rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: .08em;
    text-transform: uppercase;
    position: relative;
    transition: color .25s;
  }
  .nav-links a::after {
    content: '';
    position: absolute; left: 0; bottom: -4px;
    width: 0; height: 1.5px;
    background: var(--neon);
    transition: width .3s ease;
  }
  .nav-links a:hover { color: var(--neon); }
  .nav-links a:hover::after { width: 100%; }
  .nav-cta {
    padding: .5rem 1.2rem;
    border: 1.5px solid var(--neon);
    border-radius: 4px;
    color: var(--neon) !important;
    font-family: var(--mono);
    font-size: .78rem !important;
    transition: background .25s, color .25s !important;
  }
  .nav-cta:hover { background: var(--neon); color: var(--bg) !important; }
  .nav-cta::after { display: none !important; }

  /* ── HAMBURGER ── */
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 200; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--text); transition: .3s; }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); background: var(--neon); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); background: var(--neon); }

  .mobile-menu {
    display: none;
    position: fixed; inset: 0;
    background: rgba(13,13,13,.97);
    z-index: 150;
    flex-direction: column;
    align-items: center; justify-content: center;
    gap: 2.5rem;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    transition: color .2s;
  }
  .mobile-menu a:hover { color: var(--neon); }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 0 5vw;
    padding-top: 80px;
    gap: 4rem;
    position: relative;
    overflow: hidden;
  }

  #hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: .25;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black, transparent);
  }

  #hero::after {
    content: '';
    position: absolute;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(57,255,20,.08) 0%, transparent 70%);
    top: 10%; right: 5%;
    border-radius: 50%;
    pointer-events: none;
    animation: blobPulse 6s ease-in-out infinite;
  }
  @keyframes blobPulse {
    0%,100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.15); opacity: .6; }
  }

  .hero-content { position: relative; z-index: 2; }

  .hero-tag {
    display: inline-flex; align-items: center; gap: .5rem;
    font-family: var(--mono);
    font-size: .75rem;
    color: var(--neon);
    border: 1px solid rgba(57,255,20,.3);
    padding: .3rem .8rem;
    border-radius: 2px;
    margin-bottom: 1.5rem;
    animation: fadeUp .6s ease both;
  }
  .hero-tag::before { content: '▶'; font-size: .5rem; }

  .hero-name {
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -.02em;
    animation: fadeUp .6s .1s ease both;
  }
  .hero-name .line1 { display: block; color: var(--text); }
  .hero-name .line2 { display: block; color: var(--neon); }

  .hero-role {
    font-family: var(--mono);
    font-size: clamp(.85rem, 1.5vw, 1rem);
    font-weight: 500;
    color: var(--text-muted);
    margin-top: 1rem;
    animation: fadeUp .6s .2s ease both;
  }
  .hero-role span { color: var(--neon); }

  .hero-desc {
    margin-top: 1.5rem;
    font-size: .92rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 480px;
    animation: fadeUp .6s .3s ease both;
  }

  .hero-btns {
    display: flex; gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    animation: fadeUp .6s .4s ease both;
  }

  .btn-primary {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--neon);
    color: var(--bg);
    font-family: var(--font);
    font-weight: 700;
    font-size: .85rem;
    padding: .75rem 1.6rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background .25s, transform .2s, box-shadow .25s;
    letter-spacing: .03em;
  }
  .btn-primary:hover {
    background: var(--neon-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(57,255,20,.25);
  }
  .btn-secondary {
    display: inline-flex; align-items: center; gap: .5rem;
    background: transparent;
    color: var(--neon);
    font-family: var(--font);
    font-weight: 600;
    font-size: .85rem;
    padding: .75rem 1.6rem;
    border-radius: 4px;
    border: 1.5px solid var(--neon);
    cursor: pointer;
    text-decoration: none;
    transition: background .25s, transform .2s;
    letter-spacing: .03em;
  }
  .btn-secondary:hover {
    background: rgba(57,255,20,.08);
    transform: translateY(-2px);
  }

  .hero-stats {
    display: flex; gap: 2.5rem;
    margin-top: 3rem;
    animation: fadeUp .6s .5s ease both;
  }
  .stat-item { display: flex; flex-direction: column; }
  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }
  .stat-number span { color: var(--neon); }
  .stat-label {
    font-size: .72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-top: .25rem;
  }

  .hero-visual {
    position: relative; z-index: 2;
    animation: fadeUp .6s .3s ease both;
  }
  .terminal-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,.5), 0 0 0 1px rgba(57,255,20,.05);
  }
  .terminal-bar {
    display: flex; align-items: center; gap: .5rem;
    padding: .9rem 1.2rem;
    background: #111;
    border-bottom: 1px solid var(--border);
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; }
  .dot-r { background: #FF5F56; }
  .dot-y { background: #FFBD2E; }
  .dot-g { background: #27C93F; }
  .terminal-title {
    font-family: var(--mono);
    font-size: .72rem;
    color: var(--text-muted);
    margin-left: .5rem;
  }
  .terminal-body { padding: 1.5rem; font-family: var(--mono); font-size: .82rem; line-height: 2; }
  .t-line { display: flex; align-items: baseline; gap: .5rem; }
  .t-prompt { color: var(--neon); user-select: none; }
  .t-cmd { color: var(--text); }
  .t-out { color: var(--text-muted); padding-left: 1.3rem; }
  .t-key { color: #61dafb; }
  .t-val { color: #f8d06b; }
  .t-str { color: var(--neon); }
  .t-cursor {
    display: inline-block; width: 8px; height: 1em;
    background: var(--neon);
    animation: blink .8s step-end infinite;
    vertical-align: text-bottom;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ── SECTION COMMONS ── */
  section { padding: 7rem 5vw; }
  .section-label {
    display: inline-flex; align-items: center; gap: .6rem;
    font-family: var(--mono);
    font-size: .75rem;
    color: var(--neon);
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .section-label::before { content: '//'; opacity: .5; }
  h2.section-title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: .5rem;
  }
  h2.section-title em { color: var(--neon); font-style: normal; }
  .section-sub {
    font-size: .9rem;
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 3.5rem;
  }
  .divider {
    width: 40px; height: 3px;
    background: var(--neon);
    margin: 1rem 0 2rem;
    border-radius: 2px;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── ABOUT ── */
  #about { background: var(--surface); position: relative; overflow: hidden; }
  #about::before {
    content: 'GB';
    position: absolute; right: 5vw; top: 50%; transform: translateY(-50%);
    font-size: 14rem;
    font-weight: 900;
    color: var(--border);
    pointer-events: none;
    line-height: 1;
    letter-spacing: -.05em;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }
  .about-info p {
    font-size: .9rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.2rem;
  }
  .about-info p strong { color: var(--text); }
  .about-contact {
    margin-top: 2rem;
    display: flex; flex-direction: column; gap: .8rem;
  }
  .contact-row {
    display: flex; align-items: center; gap: .75rem;
    font-size: .83rem; color: var(--text-muted);
  }
  .contact-row .icon { color: var(--neon); font-size: 1rem; min-width: 18px; }
  .contact-row a { color: var(--text-muted); text-decoration: none; transition: color .2s; }
  .contact-row a:hover { color: var(--neon); }

  /* ── ABOUT RIGHT COLUMN ── */
  .about-right { display: flex; flex-direction: column; gap: 2.5rem; }

  /* Photo placeholder */
  .photo-placeholder {
    width: 100%;
    aspect-ratio: 4/5;
    max-width: 320px;
    background: var(--bg);
    border: 2px dashed rgba(57,255,20,.3);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: border-color .3s;
  }
  .photo-placeholder:hover { border-color: rgba(57,255,20,.6); }
  .photo-placeholder::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 50% 40%, rgba(57,255,20,.04) 0%, transparent 70%);
  }
  .photo-placeholder-icon {
    font-size: 3rem;
    opacity: .3;
  }
  .photo-placeholder-label {
    font-family: var(--mono);
    font-size: .72rem;
    color: var(--text-muted);
    letter-spacing: .1em;
    text-align: center;
    opacity: .6;
  }
  .photo-placeholder-sub {
    font-family: var(--mono);
    font-size: .65rem;
    color: var(--neon-dark);
    letter-spacing: .08em;
    text-align: center;
  }
  
  .corner-br {
    position: absolute;
    bottom: 12px; right: 12px;
    width: 20px; height: 20px;
    border-bottom: 2px solid var(--neon);
    border-right: 2px solid var(--neon);
    border-radius: 0 0 2px 0;
  }

  .about-timeline { display: flex; flex-direction: column; gap: 0; }
  .tl-title {
    font-family: var(--mono);
    font-size: .75rem;
    color: var(--neon);
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .tl-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1.5rem;
    position: relative;
    padding-bottom: 2rem;
  }
  .tl-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 99px; top: 8px;
    width: 1px; bottom: 0;
    background: linear-gradient(to bottom, var(--neon-dark), transparent);
  }
  .tl-year {
    font-family: var(--mono);
    font-size: .72rem;
    color: var(--neon);
    text-align: right;
    padding-top: .1rem;
    white-space: nowrap;
  }
  .tl-dot {
    position: absolute;
    left: 91px; top: 4px;
    width: 16px; height: 16px;
    border: 2px solid var(--neon);
    border-radius: 50%;
    background: var(--bg);
    box-shadow: 0 0 8px rgba(57,255,20,.4);
  }
  .tl-body h4 {
    font-size: .88rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: .2rem;
  }
  .tl-body p {
    font-size: .8rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── SKILLS ── */
  #skills { background: var(--bg); }
  .skills-outer {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .skill-group {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.8rem;
    transition: border-color .3s, box-shadow .3s, transform .3s;
  }
  .skill-group:hover {
    border-color: rgba(57,255,20,.4);
    box-shadow: 0 0 30px rgba(57,255,20,.06);
    transform: translateY(-4px);
  }
  .skill-group-title {
    font-family: var(--mono);
    font-size: .82rem;
    font-weight: 700;
    color: var(--neon);
    margin-bottom: 1.2rem;
    display: flex; align-items: center; gap: .5rem;
  }
  .skill-tags {
    display: flex; flex-wrap: wrap; gap: .5rem;
  }
  .tag {
    font-family: var(--mono);
    font-size: .72rem;
    font-weight: 500;
    padding: .3rem .7rem;
    background: rgba(57,255,20,.06);
    border: 1px solid rgba(57,255,20,.15);
    border-radius: 3px;
    color: var(--text-muted);
    transition: background .2s, color .2s, border-color .2s;
  }
  .tag:hover { background: rgba(57,255,20,.12); color: var(--neon); border-color: rgba(57,255,20,.4); }

  .skill-bars { margin-top: 3rem; }
  .skill-bar-item { margin-bottom: 1.2rem; }
  .skill-bar-head {
    display: flex; justify-content: space-between;
    font-size: .8rem; color: var(--text-muted);
    margin-bottom: .4rem;
    font-family: var(--mono);
  }
  .skill-bar-head span:last-child { color: var(--neon); }
  .bar-track {
    width: 100%; height: 4px;
    background: var(--border); border-radius: 2px; overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--neon-dark), var(--neon));
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.2s cubic-bezier(.16,1,.3,1);
  }
  .bar-fill.animated { transform: scaleX(1); }

  /* ── EXPERIENCE ── */
  #experience { background: var(--surface); }
  .exp-grid { display: flex; flex-direction: column; gap: 0; }
  .exp-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    position: relative;
    transition: background .2s;
  }
  .exp-item:first-child { border-top: 1px solid var(--border); }
  .exp-item:hover { background: rgba(57,255,20,.02); }
  .exp-company {
    font-family: var(--mono);
    font-size: .78rem;
    color: var(--neon);
    font-weight: 700;
    letter-spacing: .05em;
  }
  .exp-period {
    font-size: .75rem;
    color: var(--text-muted);
    margin-top: .3rem;
    line-height: 1.5;
  }
  .exp-badge {
    display: inline-block;
    margin-top: .6rem;
    font-family: var(--mono);
    font-size: .65rem;
    padding: .2rem .5rem;
    background: rgba(57,255,20,.1);
    border: 1px solid rgba(57,255,20,.2);
    border-radius: 2px;
    color: var(--neon);
  }
  .exp-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: .8rem;
  }
  .exp-content p {
    font-size: .85rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: .8rem;
  }
  .exp-highlights {
    display: flex; flex-direction: column; gap: .4rem;
    margin-top: .8rem;
  }
  .exp-highlight {
    display: flex; align-items: flex-start; gap: .6rem;
    font-size: .82rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .exp-highlight::before {
    content: '→';
    color: var(--neon);
    flex-shrink: 0;
    margin-top: .05rem;
  }

  /* ── PROJECTS ── */
  #projects { background: var(--bg); }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    display: flex; flex-direction: column;
    transition: border-color .3s, transform .3s, box-shadow .3s;
    position: relative; overflow: hidden;
  }
  .project-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--neon), transparent);
    transform: scaleX(0);
    transition: transform .4s ease;
  }
  .project-card:hover::before { transform: scaleX(1); }
  .project-card:hover {
    border-color: rgba(57,255,20,.3);
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(0,0,0,.4), 0 0 0 1px rgba(57,255,20,.05);
  }
  .project-num {
    font-family: var(--mono);
    font-size: .75rem;
